{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DisChord Code Studio",
  "version": "1.2.2",
  "identifier": "com.ether.dischord-code-studio-v2",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DisChord Code Studio",
        "width": 800,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "IDE para programadores de DisChord",
    "longDescription": "DisChord Code Studio es un entorno de desarrollo optimizado para la creación, gestión, despliegue de bots y aplicaciones de Discord.",
    "publisher": "Ether",
    "copyright": "Copyright © 2026 Ether",
    "category": "Development",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    },
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.1-0", "libappindicator3-1", "librsvg2-common"]
      },
      "rpm": {
        "depends": ["gtk3", "webkit2gtk4.1", "libappindicator-gtk3"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.theindiebrand.es/ide/update/{{target}}/{{current_version}}",
        "https://github.com/DisChord-Org/DisChord-Code-Studio/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMkM4NkVDODkwRDFBQzIKUldUQ0dnMko3SVlzWVRUSVRIWFJmTitTMnB4WFBHTUFqendwUWpSOFMrbHpmT0FKd3R1aFJCek8K"
    }
  }
}